#!/usr/bin/env python3
import argparse
import json
import os
import shutil
import subprocess
import sys
import time
import uuid
from pathlib import Path
from typing import Any


WORKSPACE_ROOT = Path(__file__).resolve().parents[1]
MACCONTROL = WORKSPACE_ROOT / "scripts" / "maccontrol"
DEFAULT_HOST = os.environ.get("MACCOMPUTER_HOST") or os.environ.get("MACCONTROL_HOST") or "macbox"
DEFAULT_SCREENSHOT_DIR = WORKSPACE_ROOT / ".control-runs" / "maccomputer"


class CliError(Exception):
    pass


def print_json(value: Any) -> None:
    print(json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True))


def run_maccontrol(args: list[str], *, host: str = DEFAULT_HOST, timeout: int = 20) -> dict[str, Any]:
    cmd = [str(MACCONTROL)]
    if host:
        cmd.extend(["--host", host])
    cmd.extend(args)
    last_error = ""
    for attempt in range(2):
        proc = subprocess.run(cmd, cwd=str(WORKSPACE_ROOT), text=True, capture_output=True, timeout=timeout)
        if proc.returncode != 0:
            raise CliError((proc.stderr or proc.stdout or f"maccontrol failed: {cmd}").strip())
        try:
            payload = json.loads(proc.stdout)
            break
        except json.JSONDecodeError as exc:
            last_error = f"maccontrol returned invalid JSON: {exc}\n{proc.stdout}"
            if attempt == 0 and not proc.stdout.strip():
                time.sleep(0.2)
                continue
            raise CliError(last_error) from exc
    else:
        raise CliError(last_error or "maccontrol returned invalid JSON")
    if not isinstance(payload, dict):
        raise CliError("maccontrol returned non-object JSON")
    return payload


def scp_from_mac(host: str, remote_path: str, local_path: Path, timeout: int = 20) -> None:
    local_path.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(
        ["scp", "-q", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", f"{host}:{remote_path}", str(local_path)],
        cwd=str(WORKSPACE_ROOT),
        check=True,
        timeout=timeout,
    )


def app_target_args(args: argparse.Namespace) -> list[str]:
    out: list[str] = []
    if getattr(args, "app", None):
        out.extend(["--name", args.app])
    if getattr(args, "bundle_id", None):
        out.extend(["--bundle-id", args.bundle_id])
    if getattr(args, "pid", None):
        out.extend(["--pid", str(args.pid)])
    return out


def require_ok(payload: dict[str, Any], action: str) -> None:
    if payload.get("ok") is not True:
        raise CliError(f"{action} failed: {json.dumps(payload, ensure_ascii=False)}")


