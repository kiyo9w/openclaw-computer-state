#!/usr/bin/env python3
import json
import subprocess
import time
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
COMPUTER_STATE = ROOT / "scripts" / "computer-state"
COMPUTER_WORKFLOW = ROOT / "scripts" / "computer-workflow"
MCP = ROOT / "scripts" / "computer-state-mcp"
RUN_DIR = ROOT / ".control-runs" / "evals" / time.strftime("%Y%m%d-%H%M%S")


def run(cmd: list[str], timeout: int = 60, stdin: str | None = None) -> dict[str, Any]:
    started = time.time()
    try:
        proc = subprocess.run(cmd, cwd=str(ROOT), input=stdin, text=True, capture_output=True, timeout=timeout)
        return {
            "cmd": cmd,
            "ok": proc.returncode == 0,
            "returncode": proc.returncode,
            "stdout": proc.stdout,
            "stderr": proc.stderr,
            "durationMs": int((time.time() - started) * 1000),
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "cmd": cmd,
            "ok": False,
            "returncode": 124,
            "stdout": exc.stdout or "",
            "stderr": exc.stderr or "timeout",
            "durationMs": int((time.time() - started) * 1000),
        }


def parse_json(text: str) -> dict[str, Any]:
    try:
        payload = json.loads(text)
        return payload if isinstance(payload, dict) else {"ok": False, "error": "not an object"}
    except json.JSONDecodeError as exc:
        return {"ok": False, "error": str(exc), "text": text[:500]}


def case(name: str, cmd: list[str], timeout: int = 60, stdin: str | None = None) -> dict[str, Any]:
    result = run(cmd, timeout=timeout, stdin=stdin)
    payload = parse_json(result["stdout"]) if result["stdout"].strip().startswith("{") else None
    ok = result["ok"] and (payload is None or bool(payload.get("ok", True)))
    return {"name": name, "ok": ok, "result": result, "payload": payload}


def case_expected(
    name: str,
    cmd: list[str],
    *,
    returncode: int,
    error: str | None = None,
    timeout: int = 60,
    stdin: str | None = None,
) -> dict[str, Any]:
    result = run(cmd, timeout=timeout, stdin=stdin)
    payload = parse_json(result["stdout"]) if result["stdout"].strip().startswith("{") else None
    ok = result["returncode"] == returncode
    if error is not None:
        ok = ok and isinstance(payload, dict) and payload.get("error") == error
    return {"name": name, "ok": ok, "result": result, "payload": payload}


def main() -> int:
    RUN_DIR.mkdir(parents=True, exist_ok=True)
    before = RUN_DIR / "win-before.json"
    mac_annotated = RUN_DIR / "mac-annotated.png"
    win_annotated = RUN_DIR / "win-annotated.png"
    workflow = ROOT / "examples" / "workflows" / "win-esc-smoke.json"
    workflow_report = RUN_DIR / "workflow-report.json"
    mcp_input = '{"jsonrpc":"2.0","id":1,"method":"tools/list","params":{}}\n'
    mcp_interrupt_input = '{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"computer_interrupt","arguments":{"surface":"win","mode":"check"}}}\n'
    ledger_run = "eval-act-" + time.strftime("%Y%m%d-%H%M%S")
    cases = [
        case("python syntax", ["python3", "-m", "py_compile", str(COMPUTER_STATE), str(COMPUTER_WORKFLOW), str(MCP)]),
        case("facade tools", [str(COMPUTER_STATE), "tools"]),
        case("mcp tools/list", [str(MCP)], stdin=mcp_input),
        case("mcp interrupt check", [str(MCP)], stdin=mcp_interrupt_input),
        case("mac healthcheck", [str(COMPUTER_STATE), "healthcheck", "--surface", "mac"], timeout=40),
        case("win healthcheck", [str(COMPUTER_STATE), "healthcheck", "--surface", "win"], timeout=40),
        case("mac interrupt check", [str(COMPUTER_STATE), "interrupt", "--surface", "mac", "check"], timeout=40),
        case("win interrupt check", [str(COMPUTER_STATE), "interrupt", "--surface", "win", "check"], timeout=40),
        case_expected(
            "sensitive applescript blocked",
            [str(COMPUTER_STATE), "applescript", "--surface", "mac", "--script", "return 1"],
            returncode=1,
            error="sensitive_action_requires_allow_sensitive",
            timeout=40,
        ),
        case("win save state", [str(COMPUTER_STATE), "get-state", "--surface", "win", "--max-chars", "3000", "--save-state", str(before)], timeout=60),
        case("win state diff", [str(COMPUTER_STATE), "get-state", "--surface", "win", "--max-chars", "3000", "--diff-from", str(before), "--diff-limit", "5"], timeout=60),
        case("win act esc", [str(COMPUTER_STATE), "act", "--surface", "win", "--ledger-run", ledger_run, "press-key", "--key", "ESC", "--retries", "0", "--max-chars", "2000"], timeout=60),
        case("run log", [str(COMPUTER_STATE), "run-log", "--run-id", ledger_run], timeout=30),
        case("workflow validate", [str(COMPUTER_WORKFLOW), "validate", "--file", str(workflow)], timeout=30),
        case("workflow dry-run", [str(COMPUTER_WORKFLOW), "replay", "--file", str(workflow), "--dry-run"], timeout=30),
        case("workflow replay", [str(COMPUTER_WORKFLOW), "replay", "--file", str(workflow), "--report", str(workflow_report)], timeout=90),
        case("mac annotated state", [str(COMPUTER_STATE), "annotate-state", "--surface", "mac", "--max-depth", "2", "--max-nodes", "50", "--out", str(mac_annotated)], timeout=60),
        case("win annotated state", [str(COMPUTER_STATE), "annotate-state", "--surface", "win", "--limit", "50", "--out", str(win_annotated)], timeout=60),
    ]
    summary = {
        "ok": all(item["ok"] for item in cases),
        "runDir": str(RUN_DIR),
        "cases": [
            {
                "name": item["name"],
                "ok": item["ok"],
                "durationMs": item["result"]["durationMs"],
                "returncode": item["result"]["returncode"],
                "payloadOk": item["payload"].get("ok") if isinstance(item.get("payload"), dict) else None,
            }
            for item in cases
        ],
    }
    passed = sum(1 for item in summary["cases"] if item["ok"])
    summary["passed"] = passed
    summary["failed"] = len(summary["cases"]) - passed
    summary["totalDurationMs"] = sum(item["durationMs"] for item in summary["cases"])
    markdown_lines = [
        "# OpenClaw Computer State Eval",
        "",
        f"- Status: {'PASS' if summary['ok'] else 'FAIL'}",
        f"- Cases: {passed}/{len(summary['cases'])} passed",
        f"- Total duration: {summary['totalDurationMs']} ms",
        "",
        "| Case | Status | Duration | Return Code |",
        "|---|---:|---:|---:|",
    ]
    for item in summary["cases"]:
        markdown_lines.append(
            f"| {item['name']} | {'PASS' if item['ok'] else 'FAIL'} | {item['durationMs']} ms | {item['returncode']} |"
        )
    (RUN_DIR / "report.json").write_text(json.dumps({"summary": summary, "cases": cases}, ensure_ascii=False, indent=2), encoding="utf-8")
    (RUN_DIR / "report.md").write_text("\n".join(markdown_lines) + "\n", encoding="utf-8")
    summary["reportMarkdown"] = str(RUN_DIR / "report.md")
    print(json.dumps(summary, ensure_ascii=False, indent=2))
    return 0 if summary["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
