#!/usr/bin/env python3
import json
import subprocess
import sys
from pathlib import Path
from typing import Any


WORKSPACE_ROOT = Path(__file__).resolve().parents[1]
COMPUTER_STATE = WORKSPACE_ROOT / "scripts" / "computer-state"
SERVER_NAME = "openclaw-computer-state"
SERVER_VERSION = "0.1.0"
USE_CONTENT_LENGTH = False


def schema_object(properties: dict[str, Any], required: list[str] | None = None) -> dict[str, Any]:
    return {
        "type": "object",
        "properties": properties,
        "required": required or [],
        "additionalProperties": False,
    }


SURFACE = {
    "type": "string",
    "enum": ["mac", "win"],
    "default": "mac",
    "description": "Target desktop surface. mac uses macbox/MacControl; win uses Windows MCP plus wincontrol.",
}

MAC_TARGET = {
    "app": {"type": "string", "description": "Mac application name, for example ChatGPT Atlas."},
    "bundle_id": {"type": "string", "description": "Mac bundle identifier."},
    "pid": {"type": "integer", "description": "Mac process id."},
}

GLOBAL = {
    "host": {"type": "string", "default": "macbox", "description": "SSH host for MacControl."},
    "endpoint": {"type": "string", "description": "Windows MCP endpoint URL."},
    "ledger_run": {"type": "string", "description": "Optional Windows MCP ledger run id."},
    "allow_sensitive": {
        "type": "boolean",
        "default": False,
        "description": "Pass through sensitive-action allowance for Windows MCP only when already confirmed.",
    },
}


TOOLS: list[dict[str, Any]] = [
