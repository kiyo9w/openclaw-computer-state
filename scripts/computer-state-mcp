def response(message_id: Any, result: Any) -> dict[str, Any]:
    return {"jsonrpc": "2.0", "id": message_id, "result": result}


def error_response(message_id: Any, code: int, message: str, data: Any | None = None) -> dict[str, Any]:
    payload: dict[str, Any] = {"jsonrpc": "2.0", "id": message_id, "error": {"code": code, "message": message}}
    if data is not None:
        payload["error"]["data"] = data
    return payload


def emit(payload: dict[str, Any]) -> None:
    encoded = json.dumps(payload, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
    if USE_CONTENT_LENGTH:
        sys.stdout.buffer.write(f"Content-Length: {len(encoded)}\r\n\r\n".encode("ascii") + encoded)
        sys.stdout.buffer.flush()
        return
    sys.stdout.write(encoded.decode("utf-8") + "\n")
    sys.stdout.flush()


def add_common(cmd: list[str], args: dict[str, Any]) -> None:
    surface = args.get("surface")
    if surface:
        cmd.extend(["--surface", str(surface)])
    if args.get("host"):
        cmd.extend(["--host", str(args["host"])])
    if args.get("endpoint"):
        cmd.extend(["--endpoint", str(args["endpoint"])])
    if args.get("ledger_run"):
        cmd.extend(["--ledger-run", str(args["ledger_run"])])
    if args.get("allow_sensitive"):
        cmd.append("--allow-sensitive")


def add_mac_target(cmd: list[str], args: dict[str, Any]) -> None:
    if args.get("app"):
        cmd.extend(["--app", str(args["app"])])
    if args.get("bundle_id"):
        cmd.extend(["--bundle-id", str(args["bundle_id"])])
    if args.get("pid") is not None:
        cmd.extend(["--pid", str(args["pid"])])


def run_computer_state(command: str, args: dict[str, Any]) -> dict[str, Any]:
    cmd = [str(COMPUTER_STATE), command]
    add_common(cmd, args)

    if command == "list-apps":
        if args.get("limit") is not None:
            cmd.extend(["--limit", str(args["limit"])])
    elif command == "app":
        cmd.append(str(args["mode"]))
        if args.get("name"):
            cmd.extend(["--name", str(args["name"])])
        if args.get("bundle_id"):
            cmd.extend(["--bundle-id", str(args["bundle_id"])])
        if args.get("window_x") is not None:
            cmd.extend(["--window-x", str(args["window_x"])])
        if args.get("window_y") is not None:
            cmd.extend(["--window-y", str(args["window_y"])])
        if args.get("window_width") is not None:
            cmd.extend(["--window-width", str(args["window_width"])])
        if args.get("window_height") is not None:
            cmd.extend(["--window-height", str(args["window_height"])])
    elif command == "get-state":
        add_mac_target(cmd, args)
        if args.get("max_depth") is not None:
            cmd.extend(["--max-depth", str(args["max_depth"])])
        if args.get("max_nodes") is not None:
            cmd.extend(["--max-nodes", str(args["max_nodes"])])
        if args.get("max_chars") is not None:
            cmd.extend(["--max-chars", str(args["max_chars"])])
        if args.get("copy_screenshot"):
            cmd.extend(["--copy-screenshot", str(args["copy_screenshot"])])
        if args.get("copy_screenshot_default"):
            cmd.append("--copy-screenshot-default")
        if args.get("save_state"):
            cmd.extend(["--save-state", str(args["save_state"])])
        if args.get("diff_from"):
            cmd.extend(["--diff-from", str(args["diff_from"])])
        if args.get("diff_limit") is not None:
            cmd.extend(["--diff-limit", str(args["diff_limit"])])
    elif command == "annotate-state":
        add_mac_target(cmd, args)
        cmd.extend(["--out", str(args["out"])])
        for key, flag in (
            ("limit", "--limit"),
            ("max_depth", "--max-depth"),
            ("max_nodes", "--max-nodes"),
            ("max_chars", "--max-chars"),
        ):
            if args.get(key) is not None:
                cmd.extend([flag, str(args[key])])
    elif command == "find":
        add_mac_target(cmd, args)
        cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
        if args.get("limit") is not None:
            cmd.extend(["--limit", str(args["limit"])])
        if args.get("max_match_chars") is not None:
            cmd.extend(["--max-match-chars", str(args["max_match_chars"])])
    elif command == "act":
        add_mac_target(cmd, args)
        cmd.append(str(args["action"]))
        for key, flag in (
            ("id", "--id"),
            ("query", "--query"),
            ("role", "--role"),
            ("label", "--label"),
            ("x", "--x"),
            ("y", "--y"),
            ("x1", "--x1"),
            ("y1", "--y1"),
            ("x2", "--x2"),
            ("y2", "--y2"),
            ("dx", "--dx"),
            ("dy", "--dy"),
            ("button", "--button"),
            ("clicks", "--clicks"),
            ("key", "--key"),
            ("text", "--text"),
            ("ax_action", "--ax-action"),
            ("expect", "--expect"),
            ("retries", "--retries"),
            ("settle_ms", "--settle-ms"),
            ("diff_limit", "--diff-limit"),
            ("max_depth", "--max-depth"),
            ("max_nodes", "--max-nodes"),
            ("max_chars", "--max-chars"),
        ):
            if args.get(key) is not None:
                cmd.extend([flag, str(args[key])])
        if args.get("clear"):
            cmd.append("--clear")
        if args.get("enter"):
            cmd.append("--enter")
        if args.get("include_states"):
            cmd.append("--include-states")
    elif command == "click":
        add_mac_target(cmd, args)
        if args.get("id") is not None:
            cmd.extend(["--id", str(args["id"])])
        if args.get("query"):
            cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
        if args.get("label"):
            cmd.extend(["--label", str(args["label"])])
        if args.get("x") is not None:
            cmd.extend(["--x", str(args["x"])])
        if args.get("y") is not None:
            cmd.extend(["--y", str(args["y"])])
        if args.get("button"):
            cmd.extend(["--button", str(args["button"])])
        if args.get("clicks") is not None:
            cmd.extend(["--clicks", str(args["clicks"])])
    elif command == "set-value":
        add_mac_target(cmd, args)
        cmd.extend(["--text", str(args["text"])])
        if args.get("id") is not None:
            cmd.extend(["--id", str(args["id"])])
        if args.get("query"):
            cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
        if args.get("label") is not None:
            cmd.extend(["--label", str(args["label"])])
        if args.get("x") is not None:
            cmd.extend(["--x", str(args["x"])])
        if args.get("y") is not None:
            cmd.extend(["--y", str(args["y"])])
        if args.get("enter"):
            cmd.append("--enter")
    elif command in ("type-text", "type-into"):
        if command == "type-into":
            add_mac_target(cmd, args)
        cmd.extend(["--text", str(args["text"])])
        if args.get("id") is not None:
            cmd.extend(["--id", str(args["id"])])
        if args.get("query"):
            cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
        if args.get("label"):
            cmd.extend(["--label", str(args["label"])])
        if args.get("x") is not None:
            cmd.extend(["--x", str(args["x"])])
        if args.get("y") is not None:
            cmd.extend(["--y", str(args["y"])])
        if args.get("clear"):
            cmd.append("--clear")
        if args.get("enter"):
            cmd.append("--enter")
    elif command == "perform-action":
        add_mac_target(cmd, args)
        cmd.extend(["--action", str(args["action"])])
        if args.get("id") is not None:
            cmd.extend(["--id", str(args["id"])])
        if args.get("query"):
            cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
    elif command == "select-text":
        add_mac_target(cmd, args)
        cmd.extend(["--text", str(args["text"])])
        if args.get("id") is not None:
            cmd.extend(["--id", str(args["id"])])
        if args.get("query"):
            cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
        if args.get("prefix"):
            cmd.extend(["--prefix", str(args["prefix"])])
        if args.get("suffix"):
            cmd.extend(["--suffix", str(args["suffix"])])
        if args.get("mode"):
            cmd.extend(["--mode", str(args["mode"])])
    elif command == "applescript":
        cmd.extend(["--script", str(args["script"])])
        if args.get("timeout") is not None:
            cmd.extend(["--timeout", str(args["timeout"])])
    elif command == "press-key":
        cmd.extend(["--key", str(args["key"])])
    elif command == "scroll":
        if args.get("dx") is not None:
            cmd.extend(["--dx", str(args["dx"])])
        if args.get("dy") is not None:
            cmd.extend(["--dy", str(args["dy"])])
        if args.get("x") is not None:
            cmd.extend(["--x", str(args["x"])])
        if args.get("y") is not None:
            cmd.extend(["--y", str(args["y"])])
    elif command == "drag":
        cmd.extend(["--x1", str(args["x1"]), "--y1", str(args["y1"]), "--x2", str(args["x2"]), "--y2", str(args["y2"])])
    elif command == "wait-for":
        add_mac_target(cmd, args)
        cmd.extend(["--query", str(args["query"])])
        if args.get("role"):
            cmd.extend(["--role", str(args["role"])])
        if args.get("timeout_ms") is not None:
            cmd.extend(["--timeout-ms", str(args["timeout_ms"])])
        if args.get("interval_ms") is not None:
            cmd.extend(["--interval-ms", str(args["interval_ms"])])

    proc = subprocess.run(cmd, cwd=str(WORKSPACE_ROOT), text=True, capture_output=True, timeout=60)
    if proc.returncode != 0:
        raise RuntimeError((proc.stderr or proc.stdout or f"command failed: {' '.join(cmd)}").strip())
    try:
        parsed = json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"invalid JSON from computer-state: {exc}\n{proc.stdout}") from exc
    return parsed


def tool_result(payload: dict[str, Any]) -> dict[str, Any]:
    return {
        "content": [{"type": "text", "text": json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True)}],
        "structuredContent": payload,
        "isError": not bool(payload.get("ok", True)),
    }


def call_tool(name: str, args: dict[str, Any]) -> dict[str, Any]:
    mapping = {
        "computer_surfaces": "surfaces",
        "computer_healthcheck": "healthcheck",
        "computer_list_apps": "list-apps",
        "computer_app": "app",
        "computer_get_state": "get-state",
        "computer_annotate_state": "annotate-state",
        "computer_find": "find",
        "computer_act": "act",
        "computer_click": "click",
        "computer_set_value": "set-value",
        "computer_type_into": "type-into",
        "computer_perform_action": "perform-action",
        "computer_select_text": "select-text",
        "computer_run_applescript": "applescript",
        "computer_type_text": "type-text",
        "computer_press_key": "press-key",
        "computer_scroll": "scroll",
        "computer_drag": "drag",
        "computer_wait_for": "wait-for",
    }
    if name not in mapping:
        raise ValueError(f"unknown tool: {name}")
    return tool_result(run_computer_state(mapping[name], args))


def handle(message: dict[str, Any]) -> dict[str, Any] | None:
    method = message.get("method")
    message_id = message.get("id")
    params = message.get("params") or {}

    if method == "initialize":
        protocol_version = params.get("protocolVersion") or "2024-11-05"
        return response(
            message_id,
            {
                "protocolVersion": protocol_version,
                "capabilities": {"tools": {"listChanged": False}},
                "serverInfo": {"name": SERVER_NAME, "version": SERVER_VERSION},
            },
        )
    if method == "notifications/initialized":
        return None
    if method == "tools/list":
        return response(message_id, {"tools": TOOLS})
    if method == "tools/call":
        name = params.get("name")
        arguments = params.get("arguments") or {}
        if not isinstance(arguments, dict):
            return error_response(message_id, -32602, "arguments must be an object")
        try:
            return response(message_id, call_tool(str(name), arguments))
        except Exception as exc:
            text = str(exc)
            if len(text) > 4000:
                text = text[:3940] + f"\n...[truncated {len(str(exc)) - 3940} chars from tool error]"
            return response(
                message_id,
                {
                    "content": [{"type": "text", "text": text}],
                    "isError": True,
                },
            )
    return error_response(message_id, -32601, f"method not found: {method}")


def read_message(first_line: bytes) -> dict[str, Any] | None:
    global USE_CONTENT_LENGTH
    if first_line.lower().startswith(b"content-length:"):
        USE_CONTENT_LENGTH = True
        length_text = first_line.split(b":", 1)[1].strip()
        try:
            content_length = int(length_text)
        except ValueError as exc:
            raise json.JSONDecodeError("invalid Content-Length", length_text.decode("utf-8", "replace"), 0) from exc

        while True:
            header = sys.stdin.buffer.readline()
            if header in (b"\r\n", b"\n", b""):
                break

        body = sys.stdin.buffer.read(content_length)
        if not body:
            return None
        return json.loads(body.decode("utf-8"))

    line = first_line.strip()
    if not line:
        return None
    return json.loads(line.decode("utf-8"))


def main() -> int:
    while True:
        first_line = sys.stdin.buffer.readline()
        if first_line == b"":
            break
        try:
            message = read_message(first_line)
        except json.JSONDecodeError as exc:
            emit(error_response(None, -32700, "parse error", str(exc)))
            continue
        if message is None:
            continue
        if not isinstance(message, dict):
            emit(error_response(None, -32600, "invalid request"))
            continue
        result = handle(message)
        if result is not None:
            emit(result)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
