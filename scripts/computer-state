#!/usr/bin/env python3
import argparse
import json
import os
import re
import shutil
import subprocess
import time
import uuid
from pathlib import Path
from pathlib import PureWindowsPath
from typing import Any


WORKSPACE_ROOT = Path(__file__).resolve().parents[1]
MACCOMPUTER = WORKSPACE_ROOT / "scripts" / "maccomputer"
WINDOWS_MCP = WORKSPACE_ROOT / "scripts" / "windows-mcp-call"
WINCONTROL = WORKSPACE_ROOT / "scripts" / "wincontrol"
DEFAULT_RUN_DIR = WORKSPACE_ROOT / ".control-runs" / "computer-state"
INTERRUPT_FILE = DEFAULT_RUN_DIR / "interrupt.json"


class CliError(Exception):
    pass


class PayloadError(Exception):
    def __init__(self, payload: dict[str, Any]):
        super().__init__(str(payload.get("error") or payload))
        self.payload = payload


def print_json(value: Any) -> None:
    print(json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True))


def run_json(cmd: list[str], *, timeout: int = 30) -> dict[str, Any]:
    proc = subprocess.run(cmd, cwd=str(WORKSPACE_ROOT), text=True, capture_output=True, timeout=timeout)
    if proc.returncode != 0:
        raise CliError((proc.stderr or proc.stdout or f"command failed: {' '.join(cmd)}").strip())
    try:
        payload = json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        raise CliError(f"invalid JSON from {' '.join(cmd)}: {exc}\n{proc.stdout}") from exc
    if not isinstance(payload, dict):
        raise CliError("expected JSON object")
    return payload


def run_json_allow_status(cmd: list[str], *, timeout: int = 30) -> tuple[dict[str, Any], int]:
    proc = subprocess.run(cmd, cwd=str(WORKSPACE_ROOT), text=True, capture_output=True, timeout=timeout)
    raw = proc.stdout or proc.stderr
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError as exc:
        if proc.returncode != 0:
            raise CliError((proc.stderr or proc.stdout or f"command failed: {' '.join(cmd)}").strip())
        raise CliError(f"invalid JSON from {' '.join(cmd)}: {exc}\n{raw}") from exc
    if not isinstance(payload, dict):
        raise CliError("expected JSON object")
    return payload, proc.returncode


def run_text(cmd: list[str], *, timeout: int = 30) -> str:
    proc = subprocess.run(cmd, cwd=str(WORKSPACE_ROOT), text=True, capture_output=True, timeout=timeout)
    if proc.returncode != 0:
        raise CliError((proc.stderr or proc.stdout or f"command failed: {' '.join(cmd)}").strip())
    return proc.stdout


def require_ok(payload: dict[str, Any], action: str) -> None:
    if payload.get("ok") is not True:
        raise CliError(f"{action} failed: {json.dumps(payload, ensure_ascii=False)}")


def now_ms() -> int:
    return int(time.time() * 1000)


def read_interrupt_file() -> dict[str, Any] | None:
    if not INTERRUPT_FILE.exists():
        return None
    try:
        payload = json.loads(INTERRUPT_FILE.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        payload = {"reason": "interrupt_file_present"}
    if not isinstance(payload, dict):
        payload = {"reason": "interrupt_file_present"}
    return {"source": "interrupt-file", **payload}


def write_interrupt_file(reason: str) -> dict[str, Any]:
    DEFAULT_RUN_DIR.mkdir(parents=True, exist_ok=True)
    payload = {"reason": reason, "createdAtMs": now_ms()}
    INTERRUPT_FILE.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
    return payload


def clear_interrupt_file() -> None:
    try:
        INTERRUPT_FILE.unlink()
    except FileNotFoundError:
        pass


def physical_escape_status(args: argparse.Namespace) -> dict[str, Any]:
    try:
        if args.surface == "win":
            payload = json.loads(run_text([str(WINCONTROL), "-Action", "key-state", "-Keys", "Escape"], timeout=5))
        else:
            payload = run_json(mac_args(args) + ["key-state", "--key", "escape"], timeout=8)
        return {"source": "physical-escape", "ok": True, "pressed": bool(payload.get("pressed")), "raw": payload}
    except Exception as exc:  # best-effort safety signal; unavailability should not break read-only tools
        return {"source": "physical-escape", "ok": False, "pressed": False, "error": str(exc)}


def interrupt_status(args: argparse.Namespace) -> dict[str, Any]:
    sources: list[dict[str, Any]] = []
    file_status = read_interrupt_file()
    if file_status:
        sources.append(file_status)
    escape_status = physical_escape_status(args)
    if escape_status.get("pressed") or not escape_status.get("ok"):
        sources.append(escape_status)
    return {
        "ok": True,
        "surface": args.surface,
        "interrupted": bool(file_status or escape_status.get("pressed")),
        "sources": sources,
    }


def assert_not_interrupted(args: argparse.Namespace, action: str) -> None:
    status = interrupt_status(args)
    if status.get("interrupted"):
        raise PayloadError(
            {
                "ok": False,
                "error": "computer_use_interrupted",
                "action": action,
                "surface": args.surface,
                "interrupt": status,
            }
        )


def require_sensitive_approval(args: argparse.Namespace, action: str, reason: str) -> None:
    if getattr(args, "allow_sensitive", False):
        return
    raise PayloadError(
        {
            "ok": False,
            "error": "sensitive_action_requires_allow_sensitive",
            "action": action,
            "surface": args.surface,
            "reason": reason,
            "requiredConfirmation": "Re-run with --allow-sensitive only after explicit user approval.",
        }
    )


def run_dir(run_id: str) -> Path:
    safe = re.sub(r"[^A-Za-z0-9_.-]+", "_", run_id).strip("._") or "run"
    return DEFAULT_RUN_DIR / "runs" / safe


def redact_value(key: str, value: Any) -> Any:
    if key in {"text", "script"} and isinstance(value, str):
        return {"redacted": True, "chars": len(value)}
    return value


def args_for_log(args: argparse.Namespace) -> dict[str, Any]:
    out = {}
    for key, value in vars(args).items():
        if key == "func" or value is None:
            continue
        out[key] = redact_value(key, value)
    return out


def append_run_event(args: argparse.Namespace, event: str, payload: dict[str, Any] | None = None) -> None:
    run_id = getattr(args, "ledger_run", None)
    if not run_id:
        return
    directory = run_dir(str(run_id))
    directory.mkdir(parents=True, exist_ok=True)
    row = {
        "timestampMs": now_ms(),
        "event": event,
        "surface": getattr(args, "surface", None),
        "command": getattr(args, "command", None),
        "runId": str(run_id),
    }
    if payload:
        row.update(payload)
    with (directory / "events.jsonl").open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n")


def write_run_artifact(run_id: str, name: str, payload: dict[str, Any]) -> str:
    directory = run_dir(run_id)
    directory.mkdir(parents=True, exist_ok=True)
    path = directory / name
    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    return str(path)


def scp_from_mac(host: str, remote_path: str, local_path: Path, timeout: int = 20) -> None:
    local_path.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(
        ["scp", "-q", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", f"{host}:{remote_path}", str(local_path)],
        cwd=str(WORKSPACE_ROOT),
        check=True,
        timeout=timeout,
    )


def mac_args(args: argparse.Namespace) -> list[str]:
    out = [str(MACCOMPUTER), "--host", args.host]
    return out


def windows_global_args(args: argparse.Namespace) -> list[str]:
    out = [str(WINDOWS_MCP)]
    if getattr(args, "endpoint", None):
        out.extend(["--endpoint", args.endpoint])
    if getattr(args, "ledger_run", None):
        out.extend(["--ledger-run", args.ledger_run])
    if getattr(args, "allow_sensitive", False):
        out.append("--allow-sensitive")
    return out


def normalize_win_snapshot_text(text: str) -> str:
    try:
        decoded = json.loads(text)
        if isinstance(decoded, list):
            text = "\n".join(str(item) for item in decoded)
        elif isinstance(decoded, str):
            text = decoded
    except json.JSONDecodeError:
        pass
    replacements = {
        "âââ": "├──",
        "âââ": "└──",
        "â": "│",
        "â": "─",
        "â": "",
        "â": "–",
        "â": "—",
        "â¦": "…",
    }
    for old, new in replacements.items():
        text = text.replace(old, new)
    return re.sub(r"[\uFFFD]+", "", text)


def truncate_text(text: str, max_chars: int, flag: str = "--max-chars") -> tuple[str, bool, int]:
    original_len = len(text)
    if max_chars <= 0 or original_len <= max_chars:
        return text, False, original_len
    suffix = f"\n...[truncated {original_len - max_chars} chars; rerun with {flag} 0 for full output]"
    keep = max(0, max_chars - len(suffix))
    return text[:keep] + suffix, True, original_len


def png_size(path: str | Path) -> tuple[int | None, int | None]:
    try:
        import struct

        with Path(path).open("rb") as f:
            header = f.read(24)
        if header.startswith(b"\x89PNG\r\n\x1a\n"):
            return struct.unpack(">I", header[16:20])[0], struct.unpack(">I", header[20:24])[0]
    except OSError:
        pass
    return None, None


def screenshot_meta(payload: dict[str, Any], *, screenshot_id: str = "screenshot-0") -> dict[str, Any]:
    out = dict(payload)
    out.setdefault("id", screenshot_id)
    out.setdefault("originX", 0)
    out.setdefault("originY", 0)
    out.setdefault("zIndex", 0)
    local_path = out.get("localPath")
    if isinstance(local_path, str) and ("width" not in out or "height" not in out):
        width, height = png_size(local_path)
        if width is not None:
            out["width"] = width
        if height is not None:
            out["height"] = height
    return out


WINDOW_ROW_RE = re.compile(
    r"^(?P<name>.*?)\s+(?P<depth>-?\d+)\s+(?P<status>\S+)\s+(?P<width>\d+)\s+(?P<height>\d+)\s+(?P<handle>\d+)\s*$"
)


def parse_window_rows(text: str, section: str) -> list[dict[str, Any]]:
    marker = f"{section}:"
    if marker not in text:
        return []
    after = text.split(marker, 1)[1]
    rows: list[dict[str, Any]] = []
    for line in after.splitlines():
        if rows and not line.strip():
            break
        match = WINDOW_ROW_RE.match(line)
        if not match:
            continue
        rows.append(
            {
                "name": match.group("name").strip(),
                "depth": int(match.group("depth")),
                "status": match.group("status"),
                "width": int(match.group("width")),
                "height": int(match.group("height")),
                "handle": int(match.group("handle")),
            }
        )
    return rows


def windows_desktop_meta(text: str) -> dict[str, Any]:
    focused = parse_window_rows(text, "Focused Window")
    opened = parse_window_rows(text, "Opened Windows")
    opened_sorted = sorted(opened, key=lambda item: item["depth"])
    visible = sorted(focused + opened, key=lambda item: item["depth"])
    return {
        "focusedWindow": focused[0] if focused else None,
        "openedWindows": opened_sorted,
        "topWindow": visible[0] if visible else None,
        "windowCount": len(opened),
    }


def canonical_window(window: dict[str, Any]) -> dict[str, Any]:
    raw_id = window.get("handle", window.get("id", 0))
    out = {
        "id": int(raw_id),
        "title": str(window.get("name") or window.get("title") or ""),
    }
    if "handle" in window:
        out["handle"] = int(window["handle"])
    if "owner" in window:
        out["app"] = str(window.get("owner") or "")
    if "pid" in window:
        out["pid"] = int(window.get("pid") or 0)
    for key in ("depth", "status", "width", "height"):
        if key in window:
            out[key] = window[key]
    bounds = window.get("bounds")
    if isinstance(bounds, dict):
        clean_bounds = {key: (0 if isinstance(value, bool) else value) for key, value in bounds.items()}
        out["bounds"] = clean_bounds
        try:
            out["width"] = float(clean_bounds.get("Width", clean_bounds.get("width")))
            out["height"] = float(clean_bounds.get("Height", clean_bounds.get("height")))
        except (TypeError, ValueError):
            pass
    return out


def window_origin(window: dict[str, Any]) -> tuple[float, float] | None:
    bounds = window.get("bounds")
    if isinstance(bounds, dict):
        x = bounds.get("X", bounds.get("x", 0))
        y = bounds.get("Y", bounds.get("y", 0))
        if isinstance(x, bool):
            x = 0
        if isinstance(y, bool):
            y = 0
        try:
            return float(x), float(y)
        except (TypeError, ValueError):
            return None
    return None


def window_rect(window: dict[str, Any]) -> tuple[float, float, float, float] | None:
    bounds = window.get("bounds")
    if not isinstance(bounds, dict):
        return None
    try:
        x = float(bounds.get("X", bounds.get("x")))
        y = float(bounds.get("Y", bounds.get("y")))
        width = float(bounds.get("Width", bounds.get("width", window.get("width"))))
        height = float(bounds.get("Height", bounds.get("height", window.get("height"))))
    except (TypeError, ValueError):
        return None
    if width <= 0 or height <= 0:
        return None
    return (x, y, width, height)


def rect_overlap(a: tuple[float, float, float, float], b: tuple[float, float, float, float]) -> float:
    ax, ay, aw, ah = a
    bx, by, bw, bh = b
    x1 = max(ax, bx)
    y1 = max(ay, by)
    x2 = min(ax + aw, bx + bw)
    y2 = min(ay + ah, by + bh)
    if x2 <= x1 or y2 <= y1:
        return 0.0
    return (x2 - x1) * (y2 - y1)


def clipped_overlap_rect(
    a: tuple[float, float, float, float],
    b: tuple[float, float, float, float],
) -> tuple[float, float, float, float] | None:
    ax, ay, aw, ah = a
    bx, by, bw, bh = b
    x1 = max(ax, bx)
    y1 = max(ay, by)
    x2 = min(ax + aw, bx + bw)
    y2 = min(ay + ah, by + bh)
    if x2 <= x1 or y2 <= y1:
        return None
    return (x1, y1, x2, y2)


def union_area(rects: list[tuple[float, float, float, float]]) -> float:
    if not rects:
        return 0.0
    xs = sorted({rect[0] for rect in rects} | {rect[2] for rect in rects})
    total = 0.0
    for left, right in zip(xs, xs[1:]):
        if right <= left:
            continue
        spans = [(top, bottom) for x1, top, x2, bottom in rects if x1 < right and x2 > left]
        if not spans:
            continue
        spans.sort()
        covered = 0.0
        cur_top, cur_bottom = spans[0]
        for top, bottom in spans[1:]:
            if top > cur_bottom:
                covered += cur_bottom - cur_top
                cur_top, cur_bottom = top, bottom
            else:
                cur_bottom = max(cur_bottom, bottom)
        covered += cur_bottom - cur_top
        total += (right - left) * covered
    return total


def occlusion_info(windows: list[dict[str, Any]], selected: dict[str, Any] | None) -> dict[str, Any]:
    if not selected:
        return {"occluded": False, "occludingWindows": [], "occludedArea": 0, "occludedRatio": 0}
    selected_key = selected.get("id", selected.get("handle"))
    selected_rect = window_rect(selected)
    if selected_rect is None or selected_key is None:
        return {"occluded": False, "occludingWindows": [], "occludedArea": 0, "occludedRatio": 0}
    above: list[dict[str, Any]] = []
    overlap_rects: list[tuple[float, float, float, float]] = []
    for window in windows:
        if not isinstance(window, dict):
            continue
        window_key = window.get("id", window.get("handle"))
        if window_key == selected_key:
            break
        overlap = clipped_overlap_rect(selected_rect, window_rect(window) or (0, 0, 0, 0))
        area = ((overlap[2] - overlap[0]) * (overlap[3] - overlap[1])) if overlap else 0
        if area > 0:
            row = canonical_window(window)
            row["overlapArea"] = area
            above.append(row)
            overlap_rects.append(overlap)
    selected_area = selected_rect[2] * selected_rect[3]
    occluded_area = union_area(overlap_rects)
    return {
        "occluded": bool(above),
        "occludingWindows": above[:10],
        "occludedArea": occluded_area,
        "occludedRatio": round(min(1.0, occluded_area / selected_area), 4) if selected_area else 0,
    }


def with_wincontrol_bounds(windows: list[dict[str, Any]]) -> list[dict[str, Any]]:
    try:
        payload = json.loads(run_text([str(WINCONTROL), "-Action", "windows"], timeout=20))
    except (CliError, json.JSONDecodeError, subprocess.TimeoutExpired):
        return windows
    rows = payload.get("windows") if isinstance(payload, dict) else None
    if not isinstance(rows, list):
        return windows
    by_handle = {}
    for row in rows:
        if not isinstance(row, dict):
            continue
        try:
            by_handle[int(row.get("MainWindowHandle"))] = row
        except (TypeError, ValueError):
            continue
    enriched = []
    for win in windows:
        item = dict(win)
        try:
            row = by_handle.get(int(item.get("handle", item.get("id"))))
        except (TypeError, ValueError):
            row = None
        if isinstance(row, dict):
            bounds = row.get("Bounds")
            if isinstance(bounds, dict):
                item["bounds"] = bounds
            if row.get("ProcessName"):
                item["owner"] = row.get("ProcessName")
        enriched.append(item)
    return enriched


def find_windows(desktop: dict[str, Any], pattern: str) -> list[dict[str, Any]]:
    opened = desktop.get("openedWindows")
    if not isinstance(opened, list):
        return []
    return [win for win in opened if isinstance(win, dict) and window_matches(str(win.get("name") or ""), pattern)]


def translate_window_point(args: argparse.Namespace, x: float | None, y: float | None) -> tuple[float | None, float | None, dict[str, Any] | None]:
    if not getattr(args, "window", None) or x is None or y is None:
        return x, y, None
    cmd = [
        str(Path(__file__).resolve()),
        "window-state",
        "--surface",
        args.surface,
        "--window",
        args.window,
        "--max-chars",
        "8000",
    ]
    if getattr(args, "host", None):
        cmd.extend(["--host", args.host])
    if getattr(args, "endpoint", None):
        cmd.extend(["--endpoint", args.endpoint])
    for name, flag in (("app", "--app"), ("bundle_id", "--bundle-id"), ("pid", "--pid")):
        value = getattr(args, name, None)
        if value is not None:
            cmd.extend([flag, str(value)])
    payload = run_json(cmd, timeout=60)
    window = payload.get("window")
    if not isinstance(window, dict):
        raise CliError(f"window-state did not resolve a unique window for {args.window!r}")
    if getattr(args, "require_visible", False) and payload.get("occluded"):
        raise PayloadError(
            {
                "ok": False,
                "error": "target_window_occluded",
                "surface": args.surface,
                "windowPattern": args.window,
                "occludedRatio": payload.get("occludedRatio"),
                "occludingWindows": payload.get("occludingWindows"),
                "windowState": payload,
            }
        )
    origin = window_origin(window)
    if origin is None:
        raise CliError(f"resolved window has no usable bounds for relative coordinates: {args.window!r}")
    return origin[0] + float(x), origin[1] + float(y), payload


def find_mac_windows(windows: list[dict[str, Any]], pattern: str, args: argparse.Namespace) -> list[dict[str, Any]]:
    matches = []
    for win in windows:
        if not isinstance(win, dict):
            continue
        if args.pid is not None and int(win.get("pid") or -1) != args.pid:
            continue
        if args.app and not window_matches(str(win.get("owner") or ""), args.app):
            continue
        haystack = " ".join([str(win.get("title") or ""), str(win.get("owner") or "")]).strip()
        if window_matches(haystack, pattern):
            matches.append(win)
    return matches


def window_matches(name: str, pattern: str) -> bool:
    try:
        return bool(re.search(pattern, name, re.IGNORECASE))
    except re.error:
        return pattern.lower() in name.lower()


def write_json_file(path: str | Path, payload: dict[str, Any]) -> None:
    out = Path(path)
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True), encoding="utf-8")


def read_json_file(path: str | Path) -> dict[str, Any]:
    payload = json.loads(Path(path).read_text(encoding="utf-8"))
    if not isinstance(payload, dict):
        raise CliError(f"expected JSON object in {path}")
    return payload


def node_line(node: dict[str, Any]) -> str:
    parts = [
        str(node.get("role") or ""),
        str(node.get("title") or ""),
        str(node.get("description") or ""),
        str(node.get("value") or ""),
    ]
    return " | ".join(part.strip() for part in parts if part and part.strip())


def state_lines(payload: dict[str, Any]) -> list[str]:
    if isinstance(payload.get("nodes"), list):
        return [node_line(node) for node in payload["nodes"] if isinstance(node, dict) and node_line(node)]
    accessibility = payload.get("accessibility")
    if isinstance(accessibility, dict) and isinstance(accessibility.get("nodes"), list):
        return [node_line(node) for node in accessibility["nodes"] if isinstance(node, dict) and node_line(node)]
    if isinstance(payload.get("snapshotText"), str):
        return [line.strip() for line in payload["snapshotText"].splitlines() if line.strip()]
    return []


def compute_state_diff(before: dict[str, Any], after: dict[str, Any], limit: int = 40) -> dict[str, Any]:
    before_lines = state_lines(before)
    after_lines = state_lines(after)
    before_set = set(before_lines)
    after_set = set(after_lines)
    added = [line for line in after_lines if line not in before_set]
    removed = [line for line in before_lines if line not in after_set]
    return {
        "added": added[:limit],
        "removed": removed[:limit],
        "addedTotal": len(added),
        "removedTotal": len(removed),
        "limit": limit,
        "changed": bool(added or removed),
        "beforeLines": len(before_lines),
        "afterLines": len(after_lines),
    }


def target_nodes(nodes: list[dict[str, Any]], limit: int = 80) -> list[dict[str, Any]]:
    targets = []
    for node in nodes:
        frame = node.get("frame")
        if not isinstance(frame, dict):
            continue
        try:
            x = float(frame["x"])
            y = float(frame["y"])
            w = float(frame["width"])
            h = float(frame["height"])
        except (KeyError, TypeError, ValueError):
            continue
        if w <= 3 or h <= 3:
            continue
        label = str(node.get("id") or "")
        role = str(node.get("role") or "").replace("AX", "")
        title = str(node.get("title") or "")
        description = str(node.get("description") or "")
        value = str(node.get("value") or "")
        if role:
            label = f"{label}:{role}"
        targets.append(
            {
                "id": node.get("id"),
                "label": label,
                "role": node.get("role"),
                "title": title[:120],
                "description": description[:120],
                "value": value[:120],
                "frame": {"x": x, "y": y, "width": w, "height": h},
                "center": {"x": x + w / 2, "y": y + h / 2},
            }
        )
        if len(targets) >= limit:
            break
    return targets


WIN_TARGET_RE = re.compile(
    r'\((?P<x>\d+),(?P<y>\d+)\)\s+(?P<role>[a-zA-Z ]+?)\s+"(?P<title>.*?)"(?:\s{2,}|\s+\[|$)'
)


def windows_target_nodes(snapshot_text: str, limit: int = 80, marker_size: int = 28) -> list[dict[str, Any]]:
    targets: list[dict[str, Any]] = []
    half = max(marker_size, 8) / 2
    seen: set[tuple[int, int, str, str]] = set()
    for line in snapshot_text.splitlines():
        match = WIN_TARGET_RE.search(line)
        if not match:
            continue
        x = int(match.group("x"))
        y = int(match.group("y"))
        role = " ".join(match.group("role").split())
        title = match.group("title")
        key = (x, y, role, title)
        if key in seen:
            continue
        seen.add(key)
        target_id = len(targets) + 1
        targets.append(
            {
                "id": target_id,
                "label": str(target_id),
                "role": role,
                "title": title[:160],
                "description": line.strip()[:240],
                "value": "",
                "frame": {"x": x - half, "y": y - half, "width": half * 2, "height": half * 2},
                "center": {"x": x, "y": y},
                "source": "windows-mcp-snapshot",
            }
        )
        if len(targets) >= limit:
            break
    return targets


def draw_annotations(image_path: str | Path, out_path: str | Path, nodes: list[dict[str, Any]], limit: int = 80) -> dict[str, Any]:
    try:
        from PIL import Image, ImageDraw, ImageFont
    except ImportError as exc:
        return draw_svg_annotations(image_path, out_path, nodes, limit)

    image = Image.open(image_path).convert("RGBA")
    draw = ImageDraw.Draw(image)
    try:
        font = ImageFont.truetype("DejaVuSans.ttf", 12)
    except Exception:
        font = ImageFont.load_default()

    drawn = 0
    for target in target_nodes(nodes, limit):
        if drawn >= limit:
            break
        frame = target["frame"]
        x = frame["x"]
        y = frame["y"]
        w = frame["width"]
        h = frame["height"]
        label = str(target["label"])
        draw.rectangle((x, y, x + w, y + h), outline=(255, 60, 60, 230), width=2)
        text_box = draw.textbbox((x, y), label, font=font)
        pad = 2
        draw.rectangle(
            (text_box[0] - pad, text_box[1] - pad, text_box[2] + pad, text_box[3] + pad),
            fill=(255, 60, 60, 210),
        )
        draw.text((x, y), label, fill=(255, 255, 255, 255), font=font)
        drawn += 1

    out = Path(out_path)
    out.parent.mkdir(parents=True, exist_ok=True)
    image.save(out)
    return {"path": str(out), "format": "png", "boxes": drawn, "limit": limit, "source": str(image_path)}


def draw_svg_annotations(image_path: str | Path, out_path: str | Path, nodes: list[dict[str, Any]], limit: int = 80) -> dict[str, Any]:
    import html
    import struct

    boxes = []
    max_x = 1.0
    max_y = 1.0
    try:
        with Path(image_path).open("rb") as f:
            header = f.read(24)
        if header.startswith(b"\x89PNG\r\n\x1a\n"):
            max_x = float(struct.unpack(">I", header[16:20])[0])
            max_y = float(struct.unpack(">I", header[20:24])[0])
    except OSError:
        pass
    for target in target_nodes(nodes, limit):
        if len(boxes) >= limit:
            break
        frame = target["frame"]
        x = frame["x"]
        y = frame["y"]
        w = frame["width"]
        h = frame["height"]
        label = str(target["label"])
        max_x = max(max_x, x + w)
        max_y = max(max_y, y + h)
        boxes.append((x, y, w, h, label))

    out = Path(out_path)
    if out.suffix.lower() == ".png":
        out = out.with_suffix(".svg")
    out.parent.mkdir(parents=True, exist_ok=True)
    href = Path(image_path).resolve().as_uri()
    parts = [
        f'<svg xmlns="http://www.w3.org/2000/svg" width="{max_x:.0f}" height="{max_y:.0f}" viewBox="0 0 {max_x:.0f} {max_y:.0f}">',
        f'<image href="{html.escape(href)}" x="0" y="0" width="{max_x:.0f}" height="{max_y:.0f}" preserveAspectRatio="xMinYMin meet"/>',
    ]
    for x, y, w, h, label in boxes:
        safe = html.escape(label)
        parts.append(f'<rect x="{x:.1f}" y="{y:.1f}" width="{w:.1f}" height="{h:.1f}" fill="none" stroke="#ff3b30" stroke-width="2"/>')
        parts.append(f'<rect x="{x:.1f}" y="{y:.1f}" width="{max(24, len(label) * 7):.1f}" height="17" fill="#ff3b30" opacity="0.88"/>')
        parts.append(f'<text x="{x + 3:.1f}" y="{y + 12:.1f}" fill="white" font-size="12" font-family="monospace">{safe}</text>')
    parts.append("</svg>")
    out.write_text("\n".join(parts), encoding="utf-8")
    return {"path": str(out), "format": "svg", "boxes": len(boxes), "limit": limit, "source": str(image_path)}


def capture_state(args: argparse.Namespace) -> dict[str, Any]:
    if args.surface == "mac":
        cmd = mac_args(args) + ["get-state", "--max-depth", str(args.max_depth), "--max-nodes", str(args.max_nodes)]
        if args.app:
            cmd.extend(["--app", args.app])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        if args.pid:
            cmd.extend(["--pid", str(args.pid)])
        if args.copy_screenshot:
            cmd.extend(["--copy-screenshot", args.copy_screenshot])
        if args.copy_screenshot_default:
            cmd.append("--copy-screenshot-default")
        payload = run_json(cmd, timeout=40)
        payload["surface"] = "mac"
        return payload

    snapshot = run_json(windows_global_args(args) + ["snapshot", "--output", "compact"], timeout=30)
    screenshot_info: dict[str, Any] | None = None
    if args.copy_screenshot or args.copy_screenshot_default:
        DEFAULT_RUN_DIR.mkdir(parents=True, exist_ok=True)
        win_path = rf"C:\Users\ngoka\OpenClawTools\computer-state-{uuid.uuid4().hex}.png"
        win_name = PureWindowsPath(win_path).name
        local_path = Path(args.copy_screenshot) if args.copy_screenshot else DEFAULT_RUN_DIR / win_name
        run_text([str(WINCONTROL), "-Action", "screenshot", "-Out", win_path], timeout=20)
        mounted = Path("/mnt/c/Users/ngoka/OpenClawTools") / win_name
        if mounted.exists():
            local_path.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(mounted, local_path)
            screenshot_info = screenshot_meta({"windowsPath": win_path, "localPath": str(local_path), "bytes": local_path.stat().st_size})
        else:
            screenshot_info = screenshot_meta({"windowsPath": win_path, "localPath": None, "error": "mounted screenshot missing"})

    original_text = normalize_win_snapshot_text(str(snapshot.get("text") or ""))
    text, truncated, original_len = truncate_text(original_text, args.max_chars)
    return {
        "ok": bool(snapshot.get("ok")),
        "surface": "win",
        "stateModel": "windows-mcp-snapshot+screenshot",
        "capturedAt": int(time.time()),
        "server": snapshot.get("server"),
        "desktop": windows_desktop_meta(original_text),
        "screenshot": screenshot_info,
        "snapshotText": text,
        "snapshotChars": len(text),
        "originalSnapshotChars": original_len,
        "truncated": truncated,
    }


