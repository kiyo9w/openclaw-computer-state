def command_foreground(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        raise CliError("foreground is currently implemented for the Windows surface")
    snapshot = run_json(windows_global_args(args) + ["snapshot", "--output", "compact"], timeout=20)
    text = normalize_win_snapshot_text(str(snapshot.get("text") or ""))
    desktop = windows_desktop_meta(text)
    focused = desktop.get("focusedWindow")
    matches = None
    blockers = []
    if args.expect:
        focused_name = str(focused.get("name") if isinstance(focused, dict) else "")
        matches = bool(focused_name and window_matches(focused_name, args.expect))
        if not matches:
            expected = [win for win in desktop["openedWindows"] if window_matches(str(win.get("name") or ""), args.expect)]
            if expected:
                blockers.append(
                    {
                        "type": "foreground_mismatch",
                        "message": "Expected window is open but another window is foreground.",
                        "expectedWindows": expected[:5],
                    }
                )
            else:
                blockers.append(
                    {
                        "type": "window_not_open",
                        "message": "No open window matched the expected pattern.",
                    }
                )
    print_json(
        {
            "ok": bool(snapshot.get("ok")) and (matches is not False),
            "surface": "win",
            "server": snapshot.get("server"),
            "desktop": desktop,
            "expect": args.expect,
            "focusedMatchesExpect": matches,
            "blockers": blockers,
        }
    )
    return 0 if bool(snapshot.get("ok")) and (matches is not False) else 1


def command_window_state(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        windows_payload = run_json(mac_args(args) + ["windows"], timeout=30)
        apps_payload = run_json(mac_args(args) + ["list-apps"], timeout=30)
        windows = windows_payload.get("windows") if isinstance(windows_payload.get("windows"), list) else []
        apps = apps_payload.get("apps") if isinstance(apps_payload.get("apps"), list) else []
        active_app = next((app for app in apps if isinstance(app, dict) and app.get("active")), None)
        active_pid = int(active_app.get("pid")) if isinstance(active_app, dict) and active_app.get("pid") is not None else None
        matches = find_mac_windows(windows, args.window, args)
        top = windows[0] if windows else None
        focused = next((win for win in windows if isinstance(win, dict) and active_pid is not None and int(win.get("pid") or -1) == active_pid), None)
        selected = matches[0] if len(matches) == 1 else None

        screenshot_info: dict[str, Any] | None = None
        if args.copy_screenshot or args.copy_screenshot_default:
            state = capture_state(args)
            screenshot_info = state.get("screenshot") if isinstance(state.get("screenshot"), dict) else None

        result = {
            "ok": bool(windows_payload.get("ok")) and selected is not None,
            "surface": "mac",
            "stateModel": "mac-window-state/cgwindowlist+screenshot",
            "windowPattern": args.window,
            "window": canonical_window(selected) if selected else None,
            "matches": [canonical_window(win) for win in matches[:10]],
            "matchCount": len(matches),
            "isFocused": bool(
                selected
                and active_pid is not None
                and int(selected.get("pid") or -1) == active_pid
            ),
            "isTopWindow": bool(
                selected
                and isinstance(top, dict)
                and int(selected.get("id") or -1) == int(top.get("id") or -2)
            ),
            "focusedWindow": canonical_window(focused) if isinstance(focused, dict) else None,
            "topWindow": canonical_window(top) if isinstance(top, dict) else None,
            "activeApp": active_app,
            "windows": [canonical_window(win) for win in windows[:20] if isinstance(win, dict)],
            "windowCount": len(windows),
            "screenshot": screenshot_info,
            "capturedAt": int(time.time()),
            "blockers": [],
        }
        result.update(occlusion_info([win for win in windows if isinstance(win, dict)], selected))
        if len(matches) == 0:
            result["blockers"].append({"type": "window_not_open", "message": "No open window matched the requested pattern."})
        elif len(matches) > 1:
            result["blockers"].append({"type": "ambiguous_window", "message": "Multiple open windows matched the requested pattern."})
        elif result["occluded"]:
            result["blockers"].append(
                {
                    "type": "window_occluded",
                    "message": "Target window is open but partially covered by another window.",
                    "occludingWindows": result["occludingWindows"],
                    "occludedRatio": result["occludedRatio"],
                }
            )
        print_json(result)
        return 0 if result["ok"] else 1

    payload = capture_state(args)
    desktop = payload.get("desktop") if isinstance(payload.get("desktop"), dict) else {}
    if isinstance(desktop.get("openedWindows"), list):
        desktop["openedWindows"] = with_wincontrol_bounds(desktop["openedWindows"])
    if isinstance(desktop.get("focusedWindow"), dict):
        desktop["focusedWindow"] = with_wincontrol_bounds([desktop["focusedWindow"]])[0]
    if isinstance(desktop.get("topWindow"), dict):
        desktop["topWindow"] = with_wincontrol_bounds([desktop["topWindow"]])[0]
    matches = find_windows(desktop, args.window)
    focused = desktop.get("focusedWindow") if isinstance(desktop, dict) else None
    top = desktop.get("topWindow") if isinstance(desktop, dict) else None
    selected = matches[0] if len(matches) == 1 else None
    window = canonical_window(selected) if selected else None

    result = {
        "ok": bool(payload.get("ok")) and selected is not None,
        "surface": "win",
        "stateModel": "windows-window-state/windows-mcp-snapshot+screenshot",
        "windowPattern": args.window,
        "window": window,
        "matches": [canonical_window(win) for win in matches[:10]],
        "matchCount": len(matches),
        "isFocused": bool(
            selected
            and isinstance(focused, dict)
            and int(focused.get("handle", -1)) == int(selected.get("handle", -2))
        ),
        "isTopWindow": bool(
            selected
            and isinstance(top, dict)
            and int(top.get("handle", -1)) == int(selected.get("handle", -2))
        ),
        "focusedWindow": canonical_window(focused) if isinstance(focused, dict) else None,
        "topWindow": canonical_window(top) if isinstance(top, dict) else None,
        "desktop": desktop,
        "screenshot": payload.get("screenshot"),
        "server": payload.get("server"),
        "capturedAt": payload.get("capturedAt"),
        "blockers": [],
    }
    ordered_windows = desktop.get("openedWindows") if isinstance(desktop.get("openedWindows"), list) else []
    result.update(occlusion_info([win for win in ordered_windows if isinstance(win, dict)], selected))
    if len(matches) == 0:
        result["blockers"].append({"type": "window_not_open", "message": "No open window matched the requested pattern."})
    elif len(matches) > 1:
        result["blockers"].append({"type": "ambiguous_window", "message": "Multiple open windows matched the requested pattern."})
    elif result["occluded"]:
        result["blockers"].append(
            {
                "type": "window_occluded",
                "message": "Target window is open but partially covered by another window.",
                "occludingWindows": result["occludingWindows"],
                "occludedRatio": result["occludedRatio"],
            }
        )

    if args.include_snapshot:
        result["snapshotText"] = payload.get("snapshotText")
        result["snapshotChars"] = payload.get("snapshotChars")
        result["truncated"] = payload.get("truncated")

    print_json(result)
    return 0 if result["ok"] else 1


def command_translate_point(args: argparse.Namespace) -> int:
    x, y, window_state = translate_window_point(args, args.x, args.y)
    print_json(
        {
            "ok": True,
            "surface": args.surface,
            "windowPattern": args.window,
            "relative": {"x": args.x, "y": args.y},
            "global": {"x": x, "y": y},
            "windowState": window_state,
        }
    )
    return 0


def command_window_screenshot(args: argparse.Namespace) -> int:
    state_cmd = [
        str(Path(__file__).resolve()),
        "window-state",
        "--surface",
        args.surface,
        "--window",
        args.window,
        "--max-chars",
        str(args.max_chars),
    ]
    if args.host:
        state_cmd.extend(["--host", args.host])
    if args.endpoint:
        state_cmd.extend(["--endpoint", args.endpoint])
    for name, flag in (("app", "--app"), ("bundle_id", "--bundle-id"), ("pid", "--pid")):
        value = getattr(args, name, None)
        if value is not None:
            state_cmd.extend([flag, str(value)])
    state = run_json(state_cmd, timeout=60)
    window = state.get("window")
    if not isinstance(window, dict):
        raise CliError(f"window-state did not resolve a unique window for {args.window!r}")
    origin = window_origin(window)
    if origin is None:
        raise CliError(f"resolved window has no usable bounds for screenshot: {args.window!r}")

    DEFAULT_RUN_DIR.mkdir(parents=True, exist_ok=True)
    if args.surface == "mac":
        remote_path = f"/Users/ngotrung/OpenClawTools/maccomputer-window-{uuid.uuid4().hex}.png"
        local_path = Path(args.out) if args.out else DEFAULT_RUN_DIR / Path(remote_path).name
        shot = run_json(mac_args(args) + ["screenshot", "--window-id", str(window["id"]), "--out", remote_path], timeout=30)
        require_ok(shot, "mac window screenshot")
        scp_from_mac(args.host, remote_path, local_path)
        screenshot = screenshot_meta(
            {
                "remotePath": remote_path,
                "localPath": str(local_path),
                "width": shot.get("width"),
                "height": shot.get("height"),
            },
            screenshot_id="window-screenshot-0",
        )
    else:
        win_path = rf"C:\Users\ngoka\OpenClawTools\computer-state-window-{uuid.uuid4().hex}.png"
        win_name = PureWindowsPath(win_path).name
        local_path = Path(args.out) if args.out else DEFAULT_RUN_DIR / win_name
        shot = json.loads(run_text([str(WINCONTROL), "-Action", "window-screenshot", "-Handle", str(window["id"]), "-Out", win_path], timeout=30))
        if not shot.get("ok"):
            raise CliError(f"windows window screenshot failed: {json.dumps(shot, ensure_ascii=False)}")
        mounted = Path("/mnt/c/Users/ngoka/OpenClawTools") / win_name
        if not mounted.exists():
            raise CliError(f"mounted screenshot missing: {mounted}")
        local_path.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(mounted, local_path)
        screenshot = screenshot_meta(
            {
                "windowsPath": win_path,
                "localPath": str(local_path),
                "width": shot.get("width"),
                "height": shot.get("height"),
                "method": shot.get("method"),
            },
            screenshot_id="window-screenshot-0",
        )
    screenshot["originX"] = origin[0]
    screenshot["originY"] = origin[1]
    print_json({"ok": True, "surface": args.surface, "window": window, "windowState": state, "screenshot": screenshot})
    return 0


def command_healthcheck(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        payload = run_json(mac_args(args) + ["healthcheck"], timeout=20)
        print_json({"ok": bool(payload.get("ok")), "surface": "mac", "backend": payload})
        return 0 if payload.get("ok") else 1

    snapshot = run_json(windows_global_args(args) + ["snapshot", "--output", "compact"], timeout=20)
    text = normalize_win_snapshot_text(str(snapshot.get("text") or ""))
    ok = bool(snapshot.get("ok"))
    print_json(
        {
            "ok": ok,
            "surface": "win",
            "server": snapshot.get("server"),
            "hasSnapshotText": bool(snapshot.get("text")),
            "desktop": windows_desktop_meta(text),
        }
    )
    return 0 if ok else 1


def command_list_apps(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        payload = run_json(mac_args(args) + ["list-apps"], timeout=40)
        apps = payload.get("apps")
        if isinstance(apps, list) and args.limit > 0:
            payload["apps"] = apps[: args.limit]
            payload["truncated"] = len(apps) > args.limit
            payload["totalApps"] = len(apps)
            payload["limit"] = args.limit
        print_json(payload)
        return 0
    payload = run_json(windows_global_args(args) + ["process", "list", "--limit", str(args.limit), "--output", "compact"], timeout=30)
    print_json({"ok": bool(payload.get("ok")), "surface": "win", "backend": "windows-mcp Process list", "result": payload})
    return 0


def command_app(args: argparse.Namespace) -> int:
    if args.mode == "quit":
        require_sensitive_approval(args, "app quit", "Quitting an app can discard unsaved user state.")
    if args.surface == "mac":
        mode_map = {"launch": "open", "switch": "focus", "quit": "quit", "open": "open", "focus": "focus"}
        mode = mode_map.get(args.mode)
        if not mode:
            raise CliError(f"Mac app mode not supported: {args.mode}")
        cmd = mac_args(args) + ["app", mode]
        if args.name:
            cmd.extend(["--app", args.name])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        print_json(run_json(cmd, timeout=20))
        return 0

    mode_map = {"open": "launch", "focus": "switch", "launch": "launch", "switch": "switch", "resize": "resize"}
    mode = mode_map.get(args.mode)
    if not mode:
        raise CliError(f"Windows app mode not supported: {args.mode}")
    cmd = windows_global_args(args) + ["app", mode, "--output", "compact"]
    if args.name:
        cmd.extend(["--name", args.name])
    if args.window_x is not None and args.window_y is not None:
        cmd.extend(["--window-loc", str(args.window_x), str(args.window_y)])
    if args.window_width is not None and args.window_height is not None:
        cmd.extend(["--window-size", str(args.window_width), str(args.window_height)])
    print_json(run_json(cmd, timeout=20))
    return 0


def command_get_state(args: argparse.Namespace) -> int:
    payload = capture_state(args)
    if args.diff_from:
        payload["stateDiff"] = compute_state_diff(read_json_file(args.diff_from), payload, args.diff_limit)
    if args.save_state:
        write_json_file(args.save_state, payload)
        payload["savedState"] = args.save_state
    print_json(payload)
    return 0 if payload.get("ok") else 1


def command_annotate_state(args: argparse.Namespace) -> int:
    args.copy_screenshot_default = True
    payload = capture_state(args)
    screenshot = payload.get("screenshot")
    source_path = None
    if isinstance(screenshot, dict):
        source_path = screenshot.get("localPath")
    if not source_path and isinstance(payload.get("screenshotPath"), str):
        source_path = payload.get("screenshotPath")
    if not source_path and isinstance(payload.get("path"), str):
        source_path = payload.get("path")
    if not source_path:
        raise CliError("state capture did not include a local screenshot path")
    if args.surface == "win":
        clean_nodes = windows_target_nodes(str(payload.get("snapshotText") or ""), args.limit)
        targets = target_nodes(clean_nodes, args.limit)
        annotation = draw_annotations(source_path, args.out, clean_nodes, args.limit)
        print_json({"ok": True, "surface": args.surface, "state": payload, "annotation": annotation, "targets": targets})
        return 0

    nodes = payload.get("nodes") if isinstance(payload.get("nodes"), list) else []
    if not nodes and isinstance(payload.get("accessibility"), dict):
        nested_nodes = payload["accessibility"].get("nodes")
        if isinstance(nested_nodes, list):
            nodes = nested_nodes
    clean_nodes = [node for node in nodes if isinstance(node, dict)]
    targets = target_nodes(clean_nodes, args.limit)
    annotation = draw_annotations(source_path, args.out, clean_nodes, args.limit)
    print_json({"ok": True, "surface": args.surface, "state": payload, "annotation": annotation, "targets": targets})
    return 0


def command_find(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        cmd = mac_args(args) + ["find", "--query", args.query, "--limit", str(args.limit)]
        if args.role:
            cmd.extend(["--role", args.role])
        if args.app:
            cmd.extend(["--app", args.app])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        if args.pid:
            cmd.extend(["--pid", str(args.pid)])
        print_json(run_json(cmd, timeout=30))
        return 0
    payload, _ = run_json_allow_status(
        windows_global_args(args) + ["snapshot-find", args.query, "--limit", str(args.limit), "--output", "json"],
        timeout=30,
    )
    matches = []
    for line in payload.get("matches", []):
        text, truncated, original_len = truncate_text(
            normalize_win_snapshot_text(str(line)),
            args.max_match_chars,
            "--max-match-chars",
        )
        matches.append({"text": text, "truncated": truncated, "originalChars": original_len})
    payload["matches"] = matches
    payload["maxMatchChars"] = args.max_match_chars
    payload["ok"] = True
    payload["surface"] = "win"
    print_json(payload)
    return 0


def state_contains(payload: dict[str, Any], query: str) -> bool:
    needle = query.lower()
    return any(needle in line.lower() for line in state_lines(payload))


def run_action_once(args: argparse.Namespace) -> dict[str, Any]:
    action = args.action
    cmd = [str(Path(__file__).resolve()), action, "--surface", args.surface]
    if args.host:
        cmd.extend(["--host", args.host])
    if args.endpoint:
        cmd.extend(["--endpoint", args.endpoint])
    if args.ledger_run:
        cmd.extend(["--ledger-run", args.ledger_run])
    if args.allow_sensitive:
        cmd.append("--allow-sensitive")
    for name, flag in (("app", "--app"), ("bundle_id", "--bundle-id"), ("pid", "--pid")):
        value = getattr(args, name, None)
        if value is not None:
            cmd.extend([flag, str(value)])
    for name, flag in (
        ("id", "--id"),
        ("query", "--query"),
        ("role", "--role"),
        ("label", "--label"),
        ("window", "--window"),
        ("x", "--x"),
        ("y", "--y"),
        ("x1", "--x1"),
        ("y1", "--y1"),
        ("x2", "--x2"),
        ("y2", "--y2"),
        ("dx", "--dx"),
        ("dy", "--dy"),
        ("button", "--button"),
        ("clicks", "--clicks"),
        ("key", "--key"),
        ("text", "--text"),
        ("ax_action", "--action"),
    ):
        value = getattr(args, name, None)
        if value is not None:
            cmd.extend([flag, str(value)])
    if getattr(args, "clear", False):
        cmd.append("--clear")
    if getattr(args, "enter", False):
        cmd.append("--enter")
    if getattr(args, "require_visible", False):
        cmd.append("--require-visible")
    return run_json(cmd, timeout=60)


def command_act(args: argparse.Namespace) -> int:
    if args.action not in {"click", "set-value", "type-into", "type-text", "press-key", "scroll", "drag", "perform-action"}:
        raise CliError(f"unsupported act action: {args.action}")
    run_id = args.ledger_run or uuid.uuid4().hex
    args.ledger_run = run_id
    started_at_ms = now_ms()
    append_run_event(args, "act.started", {"args": args_for_log(args)})
    before = capture_state(args)
    attempts = []
    ok = False
    after: dict[str, Any] = before
    for attempt in range(1, args.retries + 2):
        action_result = run_action_once(args)
        time.sleep(max(args.settle_ms, 0) / 1000)
        after = capture_state(args)
        expectation_ok = True if not args.expect else state_contains(after, args.expect)
        attempt_payload = {
            "attempt": attempt,
            "action": action_result,
            "expectation": {"query": args.expect, "ok": expectation_ok} if args.expect else None,
            "stateDiff": compute_state_diff(before if attempt == 1 else attempts[-1]["afterState"], after, args.diff_limit),
            "afterState": after,
        }
        attempts.append(attempt_payload)
        if action_result.get("ok", True) and expectation_ok:
            ok = True
            break
    response = {
        "ok": ok,
        "surface": args.surface,
        "action": args.action,
        "runId": run_id,
        "startedAtMs": started_at_ms,
        "completedAtMs": now_ms(),
        "attempts": [
            {k: v for k, v in attempt.items() if args.include_states or k != "afterState"}
            for attempt in attempts
        ],
        "stateDiff": compute_state_diff(before, after, args.diff_limit),
    }
    if args.include_states:
        response["beforeState"] = before
        response["afterState"] = after
    response["reportPath"] = write_run_artifact(run_id, "act-report.json", response)
    append_run_event(args, "act.completed", {"ok": ok, "reportPath": response["reportPath"], "attempts": len(attempts)})
    print_json(response)
    return 0 if ok else 1


def command_click(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        cmd = mac_args(args) + ["click"]
        if args.id is not None:
            cmd.extend(["--id", str(args.id)])
        elif args.query:
            cmd.extend(["--query", args.query])
        elif args.x is not None and args.y is not None:
            x, y, window_state = translate_window_point(args, args.x, args.y)
            cmd.extend(["--x", str(x), "--y", str(y)])
        else:
            raise CliError("click requires --id, --query, or --x/--y")
        if args.role:
            cmd.extend(["--role", args.role])
        if args.app:
            cmd.extend(["--app", args.app])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        result = run_json(cmd, timeout=20)
        if args.window and args.x is not None and args.y is not None:
            result["coordinateMode"] = "window-relative"
            result["windowState"] = window_state
            result["relative"] = {"x": args.x, "y": args.y}
        print_json(result)
        return 0

    if args.label:
        cmd = windows_global_args(args) + ["click", "--label", args.label, "--output", "compact"]
    elif args.x is not None and args.y is not None:
        x, y, window_state = translate_window_point(args, args.x, args.y)
        cmd = windows_global_args(args) + ["click", "--loc", str(int(x)), str(int(y)), "--output", "compact"]
    else:
        raise CliError("Windows click requires --label or --x/--y")
    if args.button:
        cmd.extend(["--button", args.button])
    if args.clicks:
        cmd.extend(["--clicks", str(args.clicks)])
    result = run_json(cmd, timeout=20)
    if args.window and args.x is not None and args.y is not None:
        result["coordinateMode"] = "window-relative"
        result["windowState"] = window_state
        result["relative"] = {"x": args.x, "y": args.y}
    print_json(result)
    return 0


def command_set_value(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        cmd = mac_args(args) + ["set-text", "--text", args.text]
        if args.id is not None:
            cmd.extend(["--id", str(args.id)])
        elif args.query:
            cmd.extend(["--query", args.query])
        else:
            raise CliError("Mac set-value requires --id or --query")
        if args.role:
            cmd.extend(["--role", args.role])
        if args.app:
            cmd.extend(["--app", args.app])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        print_json(run_json(cmd, timeout=20))
        return 0

    cmd = windows_global_args(args) + ["type", args.text, "--clear", "--output", "compact"]
    if args.label:
        cmd.extend(["--label", args.label])
    elif args.x is not None and args.y is not None:
        x, y, window_state = translate_window_point(args, args.x, args.y)
        cmd.extend(["--loc", str(int(x)), str(int(y))])
    else:
        raise CliError("Windows set-value requires --label or --x/--y")
    if args.enter:
        cmd.append("--enter")
    result = run_json(cmd, timeout=20)
    if args.window and args.x is not None and args.y is not None:
        result["coordinateMode"] = "window-relative"
        result["windowState"] = window_state
        result["relative"] = {"x": args.x, "y": args.y}
    print_json(result)
    return 0


def command_type_into(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        cmd = mac_args(args) + ["type-into", "--text", args.text]
        if args.id is not None:
            cmd.extend(["--id", str(args.id)])
        elif args.query:
            cmd.extend(["--query", args.query])
        else:
            raise CliError("Mac type-into requires --id or --query")
        if args.role:
            cmd.extend(["--role", args.role])
        if args.app:
            cmd.extend(["--app", args.app])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        print_json(run_json(cmd, timeout=20))
        return 0

    return command_type_text(args)


def command_perform_action(args: argparse.Namespace) -> int:
    if args.surface != "mac":
        raise CliError("perform-action is only implemented for Mac Accessibility actions")
    cmd = mac_args(args) + ["perform-action", "--action", args.action]
    if args.id is not None:
        cmd.extend(["--id", str(args.id)])
    elif args.query:
        cmd.extend(["--query", args.query])
    else:
        raise CliError("perform-action requires --id or --query")
    if args.role:
        cmd.extend(["--role", args.role])
    if args.app:
        cmd.extend(["--app", args.app])
    if args.bundle_id:
        cmd.extend(["--bundle-id", args.bundle_id])
    print_json(run_json(cmd, timeout=20))
    return 0


def command_select_text(args: argparse.Namespace) -> int:
    if args.surface != "mac":
        raise CliError("select-text is only implemented for Mac Accessibility text elements")
    cmd = mac_args(args) + ["select-text", "--text", args.text, "--mode", args.mode]
    if args.id is not None:
        cmd.extend(["--id", str(args.id)])
    elif args.query:
        cmd.extend(["--query", args.query])
    else:
        raise CliError("select-text requires --id or --query")
    if args.role:
        cmd.extend(["--role", args.role])
    if args.prefix:
        cmd.extend(["--prefix", args.prefix])
    if args.suffix:
        cmd.extend(["--suffix", args.suffix])
    if args.app:
        cmd.extend(["--app", args.app])
    if args.bundle_id:
        cmd.extend(["--bundle-id", args.bundle_id])
    print_json(run_json(cmd, timeout=20))
    return 0


def command_applescript(args: argparse.Namespace) -> int:
    if args.surface != "mac":
        raise CliError("applescript is only implemented for Mac")
    require_sensitive_approval(args, "applescript", "AppleScript can read, modify, or transmit user data through local apps.")
    print_json(run_json(mac_args(args) + ["applescript", "--script", args.script, "--timeout", str(args.timeout)], timeout=args.timeout + 5))
    return 0


def command_type_text(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        print_json(run_json(mac_args(args) + ["type-text", "--text", args.text], timeout=20))
        return 0
    cmd = windows_global_args(args) + ["type", args.text, "--output", "compact"]
    if args.label:
        cmd.extend(["--label", args.label])
    elif args.x is not None and args.y is not None:
        x, y, window_state = translate_window_point(args, args.x, args.y)
        cmd.extend(["--loc", str(int(x)), str(int(y))])
    else:
        raise CliError("Windows type-text requires --label or --x/--y")
    if args.clear:
        cmd.append("--clear")
    if args.enter:
        cmd.append("--enter")
    result = run_json(cmd, timeout=20)
    if args.window and args.x is not None and args.y is not None:
        result["coordinateMode"] = "window-relative"
        result["windowState"] = window_state
        result["relative"] = {"x": args.x, "y": args.y}
    print_json(result)
    return 0


def command_press_key(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        print_json(run_json(mac_args(args) + ["press-key", "--key", args.key], timeout=20))
        return 0
    print_json(run_json(windows_global_args(args) + ["shortcut", args.key, "--output", "compact"], timeout=20))
    return 0


def command_scroll(args: argparse.Namespace) -> int:
    x, y, window_state = translate_window_point(args, args.x, args.y)
    if args.surface == "mac":
        result = run_json(mac_args(args) + ["scroll", "--dx", str(args.dx), "--dy", str(args.dy)], timeout=20)
        if args.window and args.x is not None and args.y is not None:
            result["coordinateMode"] = "window-relative"
            result["windowState"] = window_state
            result["relative"] = {"x": args.x, "y": args.y}
        print_json(result)
        return 0
    cmd = [str(WINCONTROL), "-Action", "scroll", "-Dx", str(args.dx), "-Dy", str(args.dy)]
    if x is not None and y is not None:
        cmd.extend(["-X", str(int(x)), "-Y", str(int(y))])
    result = json.loads(run_text(cmd, timeout=20))
    if args.window and args.x is not None and args.y is not None:
        result["coordinateMode"] = "window-relative"
        result["windowState"] = window_state
        result["relative"] = {"x": args.x, "y": args.y}
    print_json(result)
    return 0


def command_drag(args: argparse.Namespace) -> int:
    x1, y1, window_state_1 = translate_window_point(args, args.x1, args.y1)
    x2, y2, window_state_2 = translate_window_point(args, args.x2, args.y2)
    if args.surface == "mac":
        result = run_json(
            mac_args(args)
            + [
                "drag",
                "--x1",
                str(x1),
                "--y1",
                str(y1),
                "--x2",
                str(x2),
                "--y2",
                str(y2),
            ],
            timeout=20,
        )
        if args.window:
            result["coordinateMode"] = "window-relative"
            result["windowState"] = window_state_1 or window_state_2
            result["relative"] = {"x1": args.x1, "y1": args.y1, "x2": args.x2, "y2": args.y2}
        print_json(result)
        return 0
    result = json.loads(
        run_text(
            [
                str(WINCONTROL),
                "-Action",
                "drag",
                "-X",
                str(int(x1)),
                "-Y",
                str(int(y1)),
                "-X2",
                str(int(x2)),
                "-Y2",
                str(int(y2)),
            ],
            timeout=20,
        )
    )
    if args.window:
        result["coordinateMode"] = "window-relative"
        result["windowState"] = window_state_1 or window_state_2
        result["relative"] = {"x1": args.x1, "y1": args.y1, "x2": args.x2, "y2": args.y2}
    print_json(result)
    return 0


def command_wait_for(args: argparse.Namespace) -> int:
    if args.surface == "mac":
        cmd = mac_args(args) + ["wait-for", "--query", args.query, "--timeout-ms", str(args.timeout_ms)]
        if args.role:
            cmd.extend(["--role", args.role])
        if args.app:
            cmd.extend(["--app", args.app])
        if args.bundle_id:
            cmd.extend(["--bundle-id", args.bundle_id])
        if args.pid:
            cmd.extend(["--pid", str(args.pid)])
        print_json(run_json(cmd, timeout=max(25, int(args.timeout_ms / 1000) + 25)))
        return 0
    deadline = time.time() + (args.timeout_ms / 1000)
    attempts = 0
    last_payload: dict[str, Any] | None = None
    while time.time() < deadline:
        attempts += 1
        payload, _ = run_json_allow_status(
            windows_global_args(args) + ["snapshot-find", args.query, "--limit", "1", "--output", "json"],
            timeout=30,
        )
        last_payload = payload
        if payload.get("matches"):
            print_json({"ok": True, "surface": "win", "query": args.query, "attempts": attempts, "match": payload["matches"][0]})
            return 0
        time.sleep(max(args.interval_ms, 50) / 1000)
    print_json({"ok": False, "surface": "win", "error": "timeout", "query": args.query, "attempts": attempts, "last": last_payload})
    return 1


def command_interrupt(args: argparse.Namespace) -> int:
    if args.mode == "set":
        write_interrupt_file(args.reason)
    elif args.mode == "clear":
        clear_interrupt_file()
    print_json(interrupt_status(args))
    return 0


def command_run_log(args: argparse.Namespace) -> int:
    directory = run_dir(args.run_id)
    events_path = directory / "events.jsonl"
    events = []
    if events_path.exists():
        for line in events_path.read_text(encoding="utf-8").splitlines():
            if line.strip():
                try:
                    events.append(json.loads(line))
                except json.JSONDecodeError:
                    events.append({"raw": line})
    artifacts = []
    if directory.exists():
        artifacts = [str(path) for path in sorted(directory.iterdir()) if path.name != "events.jsonl"]
    print_json({"ok": directory.exists(), "runId": args.run_id, "runDir": str(directory), "events": events, "artifacts": artifacts})
    return 0 if directory.exists() else 1


def add_surface(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--surface", choices=["mac", "win"], default="mac")
    parser.add_argument("--host", default=os.environ.get("MACCOMPUTER_HOST", "macbox"))
    parser.add_argument("--endpoint", default=os.environ.get("WINDOWS_MCP_ENDPOINT", "http://127.0.0.1:8001/mcp"))
    parser.add_argument("--ledger-run")
    parser.add_argument("--allow-sensitive", action="store_true")


def add_target(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--app")
    parser.add_argument("--bundle-id")
    parser.add_argument("--pid", type=int)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Unified state-first desktop control facade for Mac and Windows.")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("surfaces")
    p.set_defaults(func=command_surfaces)

    p = sub.add_parser("tools")
    p.set_defaults(func=command_tools)

    p = sub.add_parser("healthcheck")
    add_surface(p)
    p.set_defaults(func=command_healthcheck)

    p = sub.add_parser("list-apps")
    add_surface(p)
    p.add_argument("--limit", type=int, default=50)
    p.set_defaults(func=command_list_apps)

    p = sub.add_parser("app")
    add_surface(p)
    p.add_argument("mode", choices=["open", "focus", "quit", "launch", "switch", "resize"])
    p.add_argument("--name")
    p.add_argument("--bundle-id")
    p.add_argument("--window-x", type=int)
    p.add_argument("--window-y", type=int)
    p.add_argument("--window-width", type=int)
    p.add_argument("--window-height", type=int)
    p.set_defaults(func=command_app)

    p = sub.add_parser("foreground")
    add_surface(p)
    p.add_argument("--expect", help="Window title regex/substr expected to be foreground")
    p.set_defaults(func=command_foreground)

    p = sub.add_parser("window-state")
    add_surface(p)
    add_target(p)
    p.add_argument("--window", required=True, help="Window title regex/substr to resolve into a canonical window object")
    p.add_argument("--max-depth", type=int, default=5)
    p.add_argument("--max-nodes", type=int, default=300)
    p.add_argument("--max-chars", type=int, default=20000, help="Windows snapshot text character cap; 0 means unlimited")
    p.add_argument("--copy-screenshot")
    p.add_argument("--copy-screenshot-default", action="store_true")
    p.add_argument("--include-snapshot", action="store_true")
    p.set_defaults(func=command_window_state)

    p = sub.add_parser("translate-point")
    add_surface(p)
    add_target(p)
    p.add_argument("--window", required=True, help="Window title regex/substr to use as coordinate origin")
    p.add_argument("--x", type=float, required=True)
    p.add_argument("--y", type=float, required=True)
    p.set_defaults(func=command_translate_point)

    p = sub.add_parser("window-screenshot")
    add_surface(p)
    add_target(p)
    p.add_argument("--window", required=True, help="Window title regex/substr to capture")
    p.add_argument("--out", help="Optional local output PNG path")
    p.add_argument("--max-chars", type=int, default=8000)
    p.set_defaults(func=command_window_screenshot)

    p = sub.add_parser("get-state")
    add_surface(p)
    add_target(p)
    p.add_argument("--max-depth", type=int, default=5)
    p.add_argument("--max-nodes", type=int, default=300)
    p.add_argument("--max-chars", type=int, default=20000, help="Windows snapshot text character cap; 0 means unlimited")
    p.add_argument("--copy-screenshot")
    p.add_argument("--copy-screenshot-default", action="store_true")
    p.add_argument("--save-state", help="Write the captured state JSON to this path for later diffing")
    p.add_argument("--diff-from", help="Compare this capture against a previously saved state JSON")
    p.add_argument("--diff-limit", type=int, default=40)
    p.set_defaults(func=command_get_state)

    p = sub.add_parser("annotate-state")
    add_surface(p)
    add_target(p)
    p.add_argument("--out", required=True)
    p.add_argument("--limit", type=int, default=80)
    p.add_argument("--max-depth", type=int, default=5)
    p.add_argument("--max-nodes", type=int, default=300)
    p.add_argument("--max-chars", type=int, default=20000)
    p.add_argument("--copy-screenshot")
    p.add_argument("--copy-screenshot-default", action="store_true")
    p.set_defaults(func=command_annotate_state)

    p = sub.add_parser("find")
    add_surface(p)
    add_target(p)
    p.add_argument("--query", required=True)
    p.add_argument("--role")
    p.add_argument("--limit", type=int, default=20)
    p.add_argument("--max-match-chars", type=int, default=500, help="Windows per-match character cap; 0 means unlimited")
    p.set_defaults(func=command_find)

    p = sub.add_parser("act")
    add_surface(p)
    add_target(p)
    p.add_argument("action", choices=["click", "set-value", "type-into", "type-text", "press-key", "scroll", "drag", "perform-action"])
    p.add_argument("--id", type=int)
    p.add_argument("--query")
    p.add_argument("--role")
    p.add_argument("--label")
    p.add_argument("--window", help="Window title regex/substr; x/y are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.add_argument("--x", type=float)
    p.add_argument("--y", type=float)
    p.add_argument("--x1", type=float)
    p.add_argument("--y1", type=float)
    p.add_argument("--x2", type=float)
    p.add_argument("--y2", type=float)
    p.add_argument("--dx", type=int)
    p.add_argument("--dy", type=int)
    p.add_argument("--button", choices=["left", "right", "middle"])
    p.add_argument("--clicks", type=int)
    p.add_argument("--key")
    p.add_argument("--text")
    p.add_argument("--ax-action", dest="ax_action")
    p.add_argument("--clear", action="store_true")
    p.add_argument("--enter", action="store_true")
    p.add_argument("--expect", help="Query that must appear in the post-action state")
    p.add_argument("--retries", type=int, default=1)
    p.add_argument("--settle-ms", type=int, default=250)
    p.add_argument("--diff-limit", type=int, default=40)
    p.add_argument("--include-states", action="store_true")
    p.add_argument("--max-depth", type=int, default=5)
    p.add_argument("--max-nodes", type=int, default=300)
    p.add_argument("--max-chars", type=int, default=20000)
    p.add_argument("--copy-screenshot")
    p.add_argument("--copy-screenshot-default", action="store_true")
    p.set_defaults(func=command_act)

    p = sub.add_parser("click")
    add_surface(p)
    add_target(p)
    p.add_argument("--id", type=int)
    p.add_argument("--query")
    p.add_argument("--role")
    p.add_argument("--label")
    p.add_argument("--window", help="Window title regex/substr; x/y are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.add_argument("--x", type=float)
    p.add_argument("--y", type=float)
    p.add_argument("--button", choices=["left", "right", "middle"], default="left")
    p.add_argument("--clicks", type=int, default=1)
    p.set_defaults(func=command_click)

    p = sub.add_parser("set-value")
    add_surface(p)
    add_target(p)
    p.add_argument("--text", required=True)
    p.add_argument("--id", type=int)
    p.add_argument("--query")
    p.add_argument("--role")
    p.add_argument("--label")
    p.add_argument("--window", help="Window title regex/substr; x/y are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.add_argument("--x", type=float)
    p.add_argument("--y", type=float)
    p.add_argument("--enter", action="store_true")
    p.set_defaults(func=command_set_value)

    p = sub.add_parser("type-into")
    add_surface(p)
    add_target(p)
    p.add_argument("--text", required=True)
    p.add_argument("--id", type=int)
    p.add_argument("--query")
    p.add_argument("--role")
    p.add_argument("--label")
    p.add_argument("--window", help="Window title regex/substr; x/y are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.add_argument("--x", type=float)
    p.add_argument("--y", type=float)
    p.add_argument("--clear", action="store_true")
    p.add_argument("--enter", action="store_true")
    p.set_defaults(func=command_type_into)

    p = sub.add_parser("perform-action")
    add_surface(p)
    add_target(p)
    p.add_argument("--action", required=True)
    p.add_argument("--id", type=int)
    p.add_argument("--query")
    p.add_argument("--role")
    p.set_defaults(func=command_perform_action)

    p = sub.add_parser("select-text")
    add_surface(p)
    add_target(p)
    p.add_argument("--text", required=True)
    p.add_argument("--id", type=int)
    p.add_argument("--query")
    p.add_argument("--role")
    p.add_argument("--prefix")
    p.add_argument("--suffix")
    p.add_argument("--mode", choices=["select", "before", "after"], default="select")
    p.set_defaults(func=command_select_text)

    p = sub.add_parser("applescript")
    add_surface(p)
    p.add_argument("--script", required=True)
    p.add_argument("--timeout", type=int, default=20)
    p.set_defaults(func=command_applescript)

    p = sub.add_parser("type-text")
    add_surface(p)
    p.add_argument("--text", required=True)
    p.add_argument("--label")
    p.add_argument("--x", type=float)
    p.add_argument("--y", type=float)
    p.add_argument("--window", help="Window title regex/substr; x/y are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.add_argument("--clear", action="store_true")
    p.add_argument("--enter", action="store_true")
    p.set_defaults(func=command_type_text)

    p = sub.add_parser("press-key")
    add_surface(p)
    p.add_argument("--key", required=True)
    p.set_defaults(func=command_press_key)

    p = sub.add_parser("scroll")
    add_surface(p)
    p.add_argument("--dx", type=int, default=0)
    p.add_argument("--dy", type=int, default=0)
    p.add_argument("--x", type=float)
    p.add_argument("--y", type=float)
    p.add_argument("--window", help="Window title regex/substr; x/y are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.set_defaults(func=command_scroll)

    p = sub.add_parser("drag")
    add_surface(p)
    p.add_argument("--x1", type=float, required=True)
    p.add_argument("--y1", type=float, required=True)
    p.add_argument("--x2", type=float, required=True)
    p.add_argument("--y2", type=float, required=True)
    p.add_argument("--window", help="Window title regex/substr; drag coordinates are interpreted as window-relative when set")
    p.add_argument("--require-visible", action="store_true", help="Block window-relative actions if the target window is occluded")
    p.set_defaults(func=command_drag)

    p = sub.add_parser("wait-for")
    add_surface(p)
    add_target(p)
    p.add_argument("--query", required=True)
    p.add_argument("--role")
    p.add_argument("--timeout-ms", type=int, default=10000)
    p.add_argument("--interval-ms", type=int, default=250)
    p.set_defaults(func=command_wait_for)

    p = sub.add_parser("interrupt")
    add_surface(p)
    p.add_argument("mode", choices=["check", "set", "clear"])
    p.add_argument("--reason", default="user_requested")
    p.set_defaults(func=command_interrupt)

    p = sub.add_parser("run-log")
    p.add_argument("--run-id", required=True)
    p.set_defaults(func=command_run_log)

    return parser


def main() -> int:
    args = build_parser().parse_args()
    mutating_commands = {
        "app",
        "act",
        "click",
        "set-value",
        "type-into",
        "perform-action",
        "select-text",
        "applescript",
        "type-text",
        "press-key",
        "scroll",
        "drag",
    }
    try:
        if args.command in mutating_commands and not getattr(args, "ledger_run", None):
            args.ledger_run = uuid.uuid4().hex
        if args.command in mutating_commands:
            append_run_event(args, "action.requested", {"args": args_for_log(args)})
            assert_not_interrupted(args, args.command)
        status = args.func(args)
        if args.command in mutating_commands:
            append_run_event(args, "action.completed", {"ok": status == 0, "status": status})
        return status
    except PayloadError as exc:
        append_run_event(args, "action.blocked", exc.payload)
        print_json(exc.payload)
        return 1
    except (CliError, subprocess.TimeoutExpired) as exc:
        append_run_event(args, "action.failed", {"ok": False, "error": str(exc)})
        print_json({"ok": False, "error": str(exc)})
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
